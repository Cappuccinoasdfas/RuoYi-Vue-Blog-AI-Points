<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.apiDoc.mapper.SysApiDocMapper">
    
    <resultMap type="SysApiDoc" id="SysApiDocResult">
        <result property="id"    column="id"    />
        <result property="moduleName"    column="module_name"    />
        <result property="apiName"    column="api_name"    />
        <result property="requestUrl"    column="request_url"    />
        <result property="requestMethod"    column="request_method"    />
        <result property="requestParams"    column="request_params"    />
        <result property="responseExample"    column="response_example"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectSysApiDocVo">
        select id, module_name, api_name, request_url, request_method, request_params, response_example, sort_order, status, remark, create_by, create_time, update_by, update_time, del_flag from sys_api_doc
    </sql>

    <select id="selectSysApiDocList" parameterType="SysApiDoc" resultMap="SysApiDocResult">
        <include refid="selectSysApiDocVo"/>
        <where>  
            <if test="moduleName != null  and moduleName != ''"> and module_name like concat('%', #{moduleName}, '%')</if>
            <if test="apiName != null  and apiName != ''"> and api_name like concat('%', #{apiName}, '%')</if>
            <if test="requestUrl != null  and requestUrl != ''"> and request_url = #{requestUrl}</if>
            <if test="requestMethod != null  and requestMethod != ''"> and request_method = #{requestMethod}</if>
            <if test="requestParams != null  and requestParams != ''"> and request_params = #{requestParams}</if>
            <if test="responseExample != null  and responseExample != ''"> and response_example = #{responseExample}</if>
            <if test="sortOrder != null "> and sort_order = #{sortOrder}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectSysApiDocById" parameterType="Long" resultMap="SysApiDocResult">
        <include refid="selectSysApiDocVo"/>
        where id = #{id}
    </select>

    <insert id="insertSysApiDoc" parameterType="SysApiDoc" useGeneratedKeys="true" keyProperty="id">
        insert into sys_api_doc
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="moduleName != null and moduleName != ''">module_name,</if>
            <if test="apiName != null and apiName != ''">api_name,</if>
            <if test="requestUrl != null and requestUrl != ''">request_url,</if>
            <if test="requestMethod != null and requestMethod != ''">request_method,</if>
            <if test="requestParams != null">request_params,</if>
            <if test="responseExample != null">response_example,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="moduleName != null and moduleName != ''">#{moduleName},</if>
            <if test="apiName != null and apiName != ''">#{apiName},</if>
            <if test="requestUrl != null and requestUrl != ''">#{requestUrl},</if>
            <if test="requestMethod != null and requestMethod != ''">#{requestMethod},</if>
            <if test="requestParams != null">#{requestParams},</if>
            <if test="responseExample != null">#{responseExample},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
         </trim>
    </insert>

    <update id="updateSysApiDoc" parameterType="SysApiDoc">
        update sys_api_doc
        <trim prefix="SET" suffixOverrides=",">
            <if test="moduleName != null and moduleName != ''">module_name = #{moduleName},</if>
            <if test="apiName != null and apiName != ''">api_name = #{apiName},</if>
            <if test="requestUrl != null and requestUrl != ''">request_url = #{requestUrl},</if>
            <if test="requestMethod != null and requestMethod != ''">request_method = #{requestMethod},</if>
            <if test="requestParams != null">request_params = #{requestParams},</if>
            <if test="responseExample != null">response_example = #{responseExample},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysApiDocById" parameterType="Long">
        delete from sys_api_doc where id = #{id}
    </delete>

    <delete id="deleteSysApiDocByIds" parameterType="String">
        delete from sys_api_doc where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>