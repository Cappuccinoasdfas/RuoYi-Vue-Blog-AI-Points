<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ai_recharge_package.mapper.AiRechargePackageMapper">
    
    <resultMap type="AiRechargePackage" id="AiRechargePackageResult">
        <result property="packageId"    column="package_id"    />
        <result property="packageName"    column="package_name"    />
        <result property="price"    column="price"    />
        <result property="basePoints"    column="base_points"    />
        <result property="bonusPoints"    column="bonus_points"    />
        <result property="totalPoints"    column="total_points"    />
        <result property="discountLabel"    column="discount_label"    />
        <result property="isRecommend"    column="is_recommend"    />
        <result property="sortOrder"    column="sort_order"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectAiRechargePackageVo">
        select package_id, package_name, price, base_points, bonus_points, total_points, discount_label, is_recommend, sort_order, status, create_time, update_time from ai_recharge_package
    </sql>

    <select id="selectAiRechargePackageList" parameterType="AiRechargePackage" resultMap="AiRechargePackageResult">
        <include refid="selectAiRechargePackageVo"/>
        <where>  
            <if test="packageName != null  and packageName != ''"> and package_name like concat('%', #{packageName}, '%')</if>
            <if test="price != null "> and price = #{price}</if>
            <if test="basePoints != null "> and base_points = #{basePoints}</if>
            <if test="bonusPoints != null "> and bonus_points = #{bonusPoints}</if>
            <if test="totalPoints != null "> and total_points = #{totalPoints}</if>
            <if test="discountLabel != null  and discountLabel != ''"> and discount_label = #{discountLabel}</if>
            <if test="isRecommend != null "> and is_recommend = #{isRecommend}</if>
            <if test="sortOrder != null "> and sort_order = #{sortOrder}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectAiRechargePackageByPackageId" parameterType="Long" resultMap="AiRechargePackageResult">
        <include refid="selectAiRechargePackageVo"/>
        where package_id = #{packageId}
    </select>

    <insert id="insertAiRechargePackage" parameterType="AiRechargePackage" useGeneratedKeys="true" keyProperty="packageId">
        insert into ai_recharge_package
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="packageName != null and packageName != ''">package_name,</if>
            <if test="price != null">price,</if>
            <if test="basePoints != null">base_points,</if>
            <if test="bonusPoints != null">bonus_points,</if>
            <if test="totalPoints != null">total_points,</if>
            <if test="discountLabel != null">discount_label,</if>
            <if test="isRecommend != null">is_recommend,</if>
            <if test="sortOrder != null">sort_order,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="packageName != null and packageName != ''">#{packageName},</if>
            <if test="price != null">#{price},</if>
            <if test="basePoints != null">#{basePoints},</if>
            <if test="bonusPoints != null">#{bonusPoints},</if>
            <if test="totalPoints != null">#{totalPoints},</if>
            <if test="discountLabel != null">#{discountLabel},</if>
            <if test="isRecommend != null">#{isRecommend},</if>
            <if test="sortOrder != null">#{sortOrder},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateAiRechargePackage" parameterType="AiRechargePackage">
        update ai_recharge_package
        <trim prefix="SET" suffixOverrides=",">
            <if test="packageName != null and packageName != ''">package_name = #{packageName},</if>
            <if test="price != null">price = #{price},</if>
            <if test="basePoints != null">base_points = #{basePoints},</if>
            <if test="bonusPoints != null">bonus_points = #{bonusPoints},</if>
            <if test="totalPoints != null">total_points = #{totalPoints},</if>
            <if test="discountLabel != null">discount_label = #{discountLabel},</if>
            <if test="isRecommend != null">is_recommend = #{isRecommend},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where package_id = #{packageId}
    </update>

    <delete id="deleteAiRechargePackageByPackageId" parameterType="Long">
        delete from ai_recharge_package where package_id = #{packageId}
    </delete>

    <delete id="deleteAiRechargePackageByPackageIds" parameterType="String">
        delete from ai_recharge_package where package_id in 
        <foreach item="packageId" collection="array" open="(" separator="," close=")">
            #{packageId}
        </foreach>
    </delete>
</mapper>