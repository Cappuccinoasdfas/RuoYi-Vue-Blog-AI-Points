<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.ai_recharge_order.mapper.AiRechargeOrderMapper">
    
    <resultMap type="AiRechargeOrder" id="AiRechargeOrderResult">
        <result property="orderId"    column="order_id"    />
        <result property="orderNo"    column="order_no"    />
        <result property="userId"    column="user_id"    />
        <result property="amount"    column="amount"    />
        <result property="points"    column="points"    />
        <result property="status"    column="status"    />
        <result property="payTime"    column="pay_time"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectAiRechargeOrderVo">
        select order_id, order_no, user_id, amount, points, status, pay_time, create_time from ai_recharge_order
    </sql>

    <select id="selectAiRechargeOrderList" parameterType="AiRechargeOrder" resultMap="AiRechargeOrderResult">
        <include refid="selectAiRechargeOrderVo"/>
        <where>  
            <if test="orderNo != null  and orderNo != ''"> and order_no = #{orderNo}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="amount != null "> and amount = #{amount}</if>
            <if test="points != null "> and points = #{points}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="payTime != null "> and pay_time = #{payTime}</if>
        </where>
    </select>
    
    <select id="selectAiRechargeOrderByOrderId" parameterType="Long" resultMap="AiRechargeOrderResult">
        <include refid="selectAiRechargeOrderVo"/>
        where order_id = #{orderId}
    </select>

    <insert id="insertAiRechargeOrder" parameterType="AiRechargeOrder" useGeneratedKeys="true" keyProperty="orderId">
        insert into ai_recharge_order
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no,</if>
            <if test="userId != null">user_id,</if>
            <if test="amount != null">amount,</if>
            <if test="points != null">points,</if>
            <if test="status != null">status,</if>
            <if test="payTime != null">pay_time,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">#{orderNo},</if>
            <if test="userId != null">#{userId},</if>
            <if test="amount != null">#{amount},</if>
            <if test="points != null">#{points},</if>
            <if test="status != null">#{status},</if>
            <if test="payTime != null">#{payTime},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateAiRechargeOrder" parameterType="AiRechargeOrder">
        update ai_recharge_order
        <trim prefix="SET" suffixOverrides=",">
            <if test="orderNo != null and orderNo != ''">order_no = #{orderNo},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="amount != null">amount = #{amount},</if>
            <if test="points != null">points = #{points},</if>
            <if test="status != null">status = #{status},</if>
            <if test="payTime != null">pay_time = #{payTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where order_id = #{orderId}
    </update>

    <delete id="deleteAiRechargeOrderByOrderId" parameterType="Long">
        delete from ai_recharge_order where order_id = #{orderId}
    </delete>

    <delete id="deleteAiRechargeOrderByOrderIds" parameterType="String">
        delete from ai_recharge_order where order_id in 
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>